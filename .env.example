# --- Base de datos (Supabase Postgres) ---
# Ve a tu proyecto de Supabase > Project Settings > Database.
# DATABASE_URL: usa la cadena del "Connection pooler" (modo transaction, puerto 6543).
# DIRECT_URL: usa la cadena de conexión directa (puerto 5432). Solo la usa Prisma para migraciones.
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Supabase Storage ---
# Ve a tu proyecto de Supabase > Project Settings > API.
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"

# --- Admin ---
# Contraseña para entrar al panel /admin. Cámbiala por algo tuyo.
ADMIN_PASSWORD="cambia-esta-contraseña"
# Cadena aleatoria larga usada para firmar la sesión del admin. Genera una con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="genera-una-cadena-aleatoria-larga"
